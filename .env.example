# Copy to `.env` and fill in. Used by both the bridge container (env_file)
# and the debug shell scripts (sourced via scripts/_lib.sh).

# MQTT broker (Mosquitto on VM A in the default deploy)
MQTT_HOST=<FRIGATE_HOST_OR_mosquitto>
MQTT_PORT=1883
MQTT_USER=bridge
MQTT_PASS=

# Gotify (HTTP target — container name on the same network, or LAN IP:port)
GOTIFY_URL=http://gotify
GOTIFY_TOKEN=
GOTIFY_PRIORITY=5

# --- Forwards ---------------------------------------------------------------
# Each FORWARD_<N>_* group is one subscription. N is any integer (sparse OK).
#   _TOPIC     required. Comma-separated MQTT topic filters. + and # wildcards
#              allowed; spaces inside a segment are fine (Frigate classification
#              labels often contain spaces).
#   _VALUES    optional. Comma-separated payloads to forward on. Unset = forward
#              every payload. Set = exact match (after strip) only.
#   _TITLE     optional. Gotify title template. Default: {topic}
#   _MESSAGE   optional. Gotify message template. Default: {payload}
#              Placeholders in _TITLE/_MESSAGE: {topic} {payload} {camera}
#              ({camera} = topic.split('/')[1], i.e. the Frigate camera name)
#   _PRIORITY  optional int. Falls back to GOTIFY_PRIORITY.
#
# A topic may match multiple slots — each slot fires independently.

FORWARD_1_TOPIC=frigate/+/classification/Brama otwarta,frigate/+/classification/Brama zamknieta
FORWARD_1_TITLE=Brama
FORWARD_1_MESSAGE={payload} ({camera})

# Example with a value filter — only fires when payload is exactly "1":
# FORWARD_2_TOPIC=frigate/+/gate_open
# FORWARD_2_TITLE=Brama
# FORWARD_2_MESSAGE=otwarta
# FORWARD_2_VALUES=1
# FORWARD_2_PRIORITY=5
